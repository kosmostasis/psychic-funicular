{
  "name": "@swarm-cdp/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\"",
    "dev:clean": "pnpm run clean && node scripts/dev-auto.mjs",
    "dev:auto": "node scripts/dev-auto.mjs",
    "dev:clean:auto": "pnpm run clean && node scripts/dev-auto.mjs",
    "build": "next build",
    "dev": "node scripts/dev-auto.mjs",
    "dev:webpack": "CDP_WEBPACK_DEV=1 WATCHPACK_POLLING=true WATCHPACK_WATCHER_LIMIT=20 CDP_DEV_POLL=1 next dev",
    "start": "next start",
    "start:3001": "next start -p 3001",
    "lint": "next lint"
  },
  "dependencies": {
    "@swarm-cdp/core": "workspace:*",
    "@swarm-cdp/db": "workspace:*",
    "@swarm-cdp/simulator-data": "workspace:*",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0"
  }
}
