{
  "name": "swarm-cdp",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "pnpm --filter @swarm-cdp/core build && pnpm --filter @swarm-cdp/simulator-data build && pnpm --filter @swarm-cdp/web dev",
    "dev:web": "pnpm --filter @swarm-cdp/web dev",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  },
  "packageManager": "pnpm@9.14.2",
  "engines": {
    "node": ">=20"
  }
}
